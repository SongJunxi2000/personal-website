---
import PostLayout from '../../layouts/PostLayout.astro';

export async function getStaticPaths() {
  const modules = import.meta.glob('../../content/stillness/*.md', { eager: true });
  return Object.entries(modules).map(([path, mod]: [string, any]) => ({
    params: { slug: path.split('/').pop()?.replace('.md', '') },
    props: { mod },
  }));
}

const { mod } = Astro.props;
const { Content, frontmatter } = mod;
---

<PostLayout
  title={frontmatter.title}
  title_zh={frontmatter.title_zh}
  date={frontmatter.date}
  excerpt={frontmatter.excerpt}
  project="stillness"
  readingTime={frontmatter.readingTime}
  autoTranslated={frontmatter.auto_translated}
>
  <Content />
</PostLayout>
