---
import type { Project } from '../lib/posts';

interface Props {
  project: Project;
  title: string;
  intro: string;
  posts: Array<{
    slug: string;
    title: string;
    date: string;
    excerpt?: string;
    url: string;
  }>;
}

const { project, title, intro, posts } = Astro.props;
---

<section class="project-index content">
  <header class="project-header fade-in">
    <h1 class="project-title">{title}</h1>
    <p class="project-intro">{intro}</p>
  </header>

  <ul class="post-list" role="list">
    {posts.map((post, i) => (
      <li class="post-item fade-in" style={`animation-delay: ${0.2 + i * 0.08}s`}>
        <a href={post.url} class="post-link">
          <time class="post-date" datetime={post.date}>
            {new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
          </time>
          <h2 class="post-title">{post.title}</h2>
          {post.excerpt && <p class="post-excerpt">{post.excerpt}</p>}
        </a>
      </li>
    ))}
  </ul>
</section>

<style>
  .project-index {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-2xl);
  }

  .project-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .project-title {
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 300;
    margin-bottom: var(--space-lg);
  }

  .project-intro {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 1.8vw, 1.15rem);
    font-style: italic;
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 560px;
    margin: 0;
  }

  .post-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .post-item {
    border-bottom: 1px solid var(--border);
  }

  .post-link {
    display: block;
    padding: var(--space-xl) 0;
    text-decoration: none;
    color: inherit;
    transition: opacity 0.3s ease;
  }

  .post-link:hover {
    opacity: 0.7;
  }

  .post-link:hover .post-title {
    transform: translateX(4px);
  }

  .post-date {
    display: block;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--text-secondary);
    margin-bottom: var(--space-sm);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    font-weight: 400;
    color: var(--text-primary);
    margin-bottom: var(--space-sm);
    transition: transform 0.3s ease;
  }

  .post-excerpt {
    font-family: var(--font-ui);
    font-size: 0.85rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin: 0;
  }
</style>
